# templates/ci/agent-mention.yml.template
#
# @-mention triggered Claude Code on issues and PRs: comment "@claude ..." and
# the action runs Claude Code against the repository with that comment as its
# task.
#
# Where this fits the methodology: AD-HOC tasks OUTSIDE the pipeline — answer
# a question about the code, triage an issue, draft a PR description, explain
# a CI failure. Anything that changes non-trivial code should still enter the
# pipeline locally via team-lead (Stage 1 — Plan onward); this workflow is the
# convenience lane, not a replacement for it.
#
# Required secret: CLAUDE_CODE_OAUTH_TOKEN
#   Generate with `claude setup-token` and add it under
#   Settings → Secrets and variables → Actions.
#
# Permissions are deliberately minimal (read-only on repo content; id-token
# for the action's auth exchange; actions:read so Claude can read CI results
# on PRs). Widen them only for a reason you can name.
#
# Copy to .github/workflows/agent-mention.yml (drop the .template suffix).

name: Claude Code

on:
  issue_comment:
    types: [created]
  pull_request_review_comment:
    types: [created]
  issues:
    types: [opened, assigned]
  pull_request_review:
    types: [submitted]

jobs:
  claude:
    if: |
      (github.event_name == 'issue_comment' && contains(github.event.comment.body, '@claude')) ||
      (github.event_name == 'pull_request_review_comment' && contains(github.event.comment.body, '@claude')) ||
      (github.event_name == 'pull_request_review' && contains(github.event.review.body, '@claude')) ||
      (github.event_name == 'issues' && (contains(github.event.issue.body, '@claude') || contains(github.event.issue.title, '@claude')))
    runs-on: ubuntu-latest
    permissions:
      contents: read
      pull-requests: read
      issues: read
      id-token: write
      actions: read # lets Claude read CI results on PRs
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 1

      - name: Run Claude Code
        id: claude
        uses: anthropics/claude-code-action@v1
        with:
          claude_code_oauth_token: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}

          # Optional: mirror the job's actions:read grant into the action.
          additional_permissions: |
            actions: read

          # Optional: a fixed prompt instead of the mention text, or extra
          # CLI flags via claude_args — see the claude-code-action docs.
          # prompt: 'Update the pull request description to summarize changes.'
          # claude_args: '--allowed-tools Bash(gh pr:*)'
